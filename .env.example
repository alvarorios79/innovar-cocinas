# ============================================================
#  INNOVAR COCINAS — Variables de Entorno
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env al repositorio (está en .gitignore).
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ── Base de datos (PostgreSQL) ───────────────────────────────
# Formato: postgresql://usuario:password@host:5432/nombre_bd
DATABASE_URL=postgresql://usuario:password@localhost:5432/innovar_prod

# ── Seguridad ────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_aleatorio_de_64_chars

# ── URL de la aplicación (para emails y WhatsApp) ────────────
VITE_APP_URL=https://app.cocinasintegralespereira.co

# ── Almacenamiento S3 (fotos de proyectos) ───────────────────
# Si usas AWS S3 o compatible (Cloudflare R2, etc.)
BUILT_IN_FORGE_API_URL=https://tu-storage-proxy.com
BUILT_IN_FORGE_API_KEY=tu_api_key_de_storage
VITE_FRONTEND_FORGE_API_URL=https://tu-storage-proxy.com

# ── Email — Resend (https://resend.com) ──────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=INNOVAR Cocinas <ventas@cocinasintegralespereira.co>

# ── WhatsApp Business Cloud API ─────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=987654321098765
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# ── Notificaciones Push Web (VAPID) ─────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:alvarorios79@gmail.com
# DEBE ser igual a VAPID_PUBLIC_KEY (lo lee el frontend vía Vite)
VITE_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OAuth (Apple Sign-In / login social) ─────────────────────
OAUTH_SERVER_URL=https://auth.manus.im
VITE_OAUTH_PORTAL_URL=https://auth.manus.im
VITE_APP_ID=innovar-cocinas

# ── Opcionales ───────────────────────────────────────────────
LOG_LEVEL=info
ENABLE_BACKUP_SCHEDULER=false
# OWNER_OPEN_ID=id_del_super_admin_en_oauth
