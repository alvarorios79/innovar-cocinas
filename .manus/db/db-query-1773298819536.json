{
  "query": "SELECT \n  c.id,\n  c.name,\n  c.email,\n  c.dataOrigin,\n  COUNT(DISTINCT q.id) as cotizaciones,\n  COUNT(DISTINCT p.id) as proyectos\nFROM clients c\nLEFT JOIN quotations q ON q.clientId = c.id AND q.deletedAt IS NULL\nLEFT JOIN projects p ON p.clientId = c.id AND p.deletedAt IS NULL\nWHERE c.deletedAt IS NULL\nGROUP BY c.id, c.name, c.email, c.dataOrigin\nORDER BY (COUNT(DISTINCT q.id) + COUNT(DISTINCT p.id)) DESC, c.name ASC;",
  "command": "mysql --batch --raw --column-names --default-character-set=utf8mb4 --host gateway03.us-east-1.prod.aws.tidbcloud.com --port 4000 --user 2bxEETtHLyojAa4.root --database XhEkCr8yXcaeDFyuQebdJQ --execute SELECT \n  c.id,\n  c.name,\n  c.email,\n  c.dataOrigin,\n  COUNT(DISTINCT q.id) as cotizaciones,\n  COUNT(DISTINCT p.id) as proyectos\nFROM clients c\nLEFT JOIN quotations q ON q.clientId = c.id AND q.deletedAt IS NULL\nLEFT JOIN projects p ON p.clientId = c.id AND p.deletedAt IS NULL\nWHERE c.deletedAt IS NULL\nGROUP BY c.id, c.name, c.email, c.dataOrigin\nORDER BY (COUNT(DISTINCT q.id) + COUNT(DISTINCT p.id)) DESC, c.name ASC;",
