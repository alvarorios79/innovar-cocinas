{
  "query": "SELECT \n  p.id,\n  p.name,\n  p.status,\n  p.isArchived,\n  p.accountingClosureId,\n  p.totalAmount,\n  COALESCE(SUM(CASE WHEN pm.movementType = 'payment' THEN pm.amount ELSE 0 END), 0) as totalPaid,\n  p.totalAmount - COALESCE(SUM(CASE WHEN pm.movementType = 'payment' THEN pm.amount ELSE 0 END), 0) as balance\nFROM projects p\nLEFT JOIN payments pm ON p.id = pm.projectId\nWHERE p.status = 'entregado'\nGROUP BY p.id, p.name, p.status, p.isArchived, p.accountingClosureId, p.totalAmount\nORDER BY p.isArchived DESC, balance ASC",
